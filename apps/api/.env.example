# TokenTimer API - Environment Configuration
# For the full variable reference, see deploy/compose/.env.example

NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokentimer
DB_USER=tokentimer
DB_PASSWORD=password

# Session
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@example.com
FROM_EMAIL_NAME=TokenTimer

# Rate limiting (API/auth)
# GLOBAL_RATE_LIMIT_WINDOW_MS=60000
# GLOBAL_RATE_LIMIT_MAX=300
# GLOBAL_SLOWDOWN_WINDOW_MS=900000
# GLOBAL_SLOWDOWN_DELAY_AFTER=50
# GLOBAL_SLOWDOWN_DELAY_MS=500
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_EMAIL_RATE_LIMIT_MAX=5
# PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
# PASSWORD_RESET_RATE_LIMIT_MAX=5
# PASSWORD_RESET_EMAIL_RATE_LIMIT_MAX=3
# EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000
# EMAIL_VERIFICATION_RATE_LIMIT_MAX=20
# AUTH_SLOWDOWN_WINDOW_MS=900000
# AUTH_SLOWDOWN_DELAY_AFTER=5
# AUTH_SLOWDOWN_DELAY_MS=500
# AUTH_SLOWDOWN_MAX_DELAY_MS=10000
# API_RATE_LIMIT_WINDOW_MS=900000
# TEST_API_RATE_LIMIT_WINDOW_MS=900000
# TEST_API_RATE_LIMIT_MAX=1000
# PLAN_API_LIMITS=oss:6000
# TEST_WEBHOOK_RATE_LIMIT_1M_WINDOW_MS=60000
# TEST_WEBHOOK_RATE_LIMIT_1M_MAX=5
# TEST_WEBHOOK_RATE_LIMIT_5M_WINDOW_MS=300000
# TEST_WEBHOOK_RATE_LIMIT_5M_MAX=10
# TEST_WEBHOOK_COOLDOWN_MS=5000

# Shared config package consumers
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000
