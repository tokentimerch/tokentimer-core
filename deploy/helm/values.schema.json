{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "sessionSecret": { "type": "string" },
        "existingSecret": { "type": "string" },
        "adminEmail": { "type": "string", "format": "email" },
        "adminPassword": { "type": "string" },
        "baseUrl": { "type": "string", "format": "uri" },
        "apiUrl": { "type": "string", "format": "uri" },
        "alertThresholds": { "type": "string", "pattern": "^[0-9]+(,[0-9]+)*$" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "cloudnative": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "instances": { "type": "integer", "minimum": 1 }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "database": { "type": "string", "minLength": 1 }
          }
        },
        "external": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "prometheusRules": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "groups": { "type": "array" }
          }
        }
      }
    }
  }
}
