{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "sessionSecret": { "type": "string" },
        "existingSecret": { "type": "string" },
        "adminEmail": {
          "type": "string",
          "anyOf": [
            { "const": "" },
            { "format": "email" }
          ]
        },
        "adminPassword": { "type": "string" },
        "adminName": { "type": "string" },
        "disableAdminBootstrap": { "type": "boolean" },
        "nodeEnv": { "type": "string", "enum": ["production", "development", "test"] },
        "baseUrl": { "type": "string", "format": "uri" },
        "apiUrl": { "type": "string", "format": "uri" },
        "trustProxyHops": { "type": "integer", "minimum": 0, "maximum": 32 },
        "alertThresholds": { "type": "string", "pattern": "^[0-9]+(,[0-9]+)*$" },
        "certopsEnabled": { "type": "boolean" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "certops": {
      "type": "object",
      "properties": {
        "controller": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["observe", "provision"] },
            "replicaCount": { "type": "integer", "minimum": 1 },
            "clusterWide": { "type": "boolean" },
            "watchNamespaces": {
              "type": "array",
              "items": { "type": "string" }
            },
            "secretFallbackEnabled": { "type": "boolean" },
            "image": {
              "type": "object",
              "properties": {
                "registry": { "type": "string" },
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "digest": { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
              }
            },
            "api": {
              "type": "object",
              "properties": {
                "url": { "type": "string" },
                "workspaceId": {
                  "type": "string",
                  "anyOf": [
                    { "const": "" },
                    { "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" }
                  ]
                },
                "clusterId": { "type": "string" }
              }
            },
            "apiToken": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "existingSecret": { "type": "string" },
                "key": { "type": "string" }
              }
            },
            "healthPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "reconcileInterval": { "type": "string" },
            "shutdownTimeout": { "type": "string" }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "cloudnative": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "instances": { "type": "integer", "minimum": 1 }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "database": { "type": "string", "minLength": 1 }
          }
        },
        "external": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressNamespace": { "type": "string" },
        "monitoringNamespace": { "type": "string" },
        "egress": {
          "type": "object",
          "properties": {
            "smtpCidrs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/(3[0-2]|[12]?[0-9])$"
              }
            },
            "httpsCidrs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/(3[0-2]|[12]?[0-9])$"
              }
            },
            "controllerApiCidrs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/(3[0-2]|[12]?[0-9])$"
              }
            },
            "controllerApiPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "kubeApiServerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "kubeApiServerCidrs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/(3[0-2]|[12]?[0-9])$"
              }
            }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "prometheusRules": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "groups": { "type": "array" }
          }
        }
      }
    }
  }
}
