# TokenTimer Core - Self-Host Configuration
# Copy this file to .env and customize for your environment.
# Variables marked (required) MUST be set for production deployments.

# ==============================
# CORE / REQUIRED
# ==============================


# Session secret (required) - generate with: openssl rand -base64 32
SESSION_SECRET=your-secret-key-here

# Database password (required)
DB_PASSWORD=your-db-password

# ==============================
# INITIAL DEPLOYMENT MODE (optional)
# ==============================
# Default compose mode builds images from local source.
# To use prebuilt images instead:
# docker compose -f docker-compose.yml -f docker-compose.images.yml up -d
#
# TT_IMAGE_REGISTRY/TT_IMAGE_OWNER are compose helpers for self-host pulls.

# TT_IMAGE_REGISTRY=ghcr.io
# TT_IMAGE_OWNER=tokentimerch
# TT_IMAGE_TAG=latest

# ==============================
# ADMIN BOOTSTRAP (first startup only)
# ==============================
# Creates the initial admin user when no users exist in the database.
# Remove or change ADMIN_PASSWORD after first login.

ADMIN_EMAIL=admin@your-company.com
ADMIN_PASSWORD=ChangeThisSecurePassword123!
ADMIN_NAME=Administrator

# Set to "true" to skip automatic admin creation
# DISABLE_ADMIN_BOOTSTRAP=true

# ==============================
# URL SETTINGS
# ==============================

# Public URL where users access the dashboard (required)
APP_URL=http://localhost:5173

# Public API URL (required)
API_URL=http://localhost:4000

# Enable Swagger UI endpoint (/api-docs) in production (default: disabled)
# ENABLE_API_DOCS=false

# ==============================
# DATABASE
# ==============================

# Compose Postgres image tag (major version must match existing data volume)
# POSTGRES_IMAGE=postgres:17-alpine

DB_HOST=postgres
DB_PORT=5432
DB_NAME=tokentimer
DB_USER=tokentimer
# DB_PASSWORD is in the REQUIRED section above

# ==============================
# EMAIL (SMTP)
# ==============================
# SMTP can be configured here OR from System Settings (admin UI).
# Precedence: System Settings DB (admin UI) > env vars here > code defaults.
# These serve as bootstrap values until an admin configures SMTP via the UI.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password

# Sender identity
# FROM_EMAIL=noreply@example.com
# FROM_EMAIL_NAME=TokenTimer

# TLS settings
# SMTP_SECURE=true              # Force SSL (auto-detected for port 465)
# SMTP_REQUIRE_TLS=true         # Require STARTTLS upgrade (default: true)

# Multi-account SMTP (comma-separated for failover/round-robin)
# SMTP_USER=account1@example.com,account2@example.com
# SMTP_PASS=pass1,pass2

# ==============================
# WHATSAPP / TWILIO (optional)
# ==============================
# WhatsApp notifications via Twilio. Can also be configured from the
# System Settings UI (admin-only). When not configured, WhatsApp
# features are hidden from the UI.

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=+14155238886

# Twilio Content Templates (for messages outside 24h session window)
# TWILIO_WHATSAPP_ALERT_CONTENT_SID_EXPIRES=HXxxxxxxxxx
# TWILIO_WHATSAPP_ALERT_CONTENT_SID_EXPIRED=HXxxxxxxxxx
# TWILIO_WHATSAPP_ALERT_CONTENT_SID_ENDPOINT_DOWN=HXxxxxxxxxx
# TWILIO_WHATSAPP_ALERT_CONTENT_SID_ENDPOINT_RECOVERED=HXxxxxxxxxx
# TWILIO_WHATSAPP_WEEKLY_DIGEST_CONTENT_SID=HXxxxxxxxxx
# TWILIO_WHATSAPP_TEST_CONTENT_SID=HXxxxxxxxxx

# Rate limit for outbound WhatsApp messages (per minute)
# WHATSAPP_RATE_PER_MIN=60

# Dry-run mode: log WhatsApp messages without sending
# WHATSAPP_DRY_RUN=false

# ==============================
# AUTHENTICATION
# ==============================

# LOCAL_AUTH_ENABLED=true              # Enable email/password login (default: true)
# REQUIRE_EMAIL_VERIFICATION=true     # Require email verification (default: true)
# TWO_FACTOR_ENABLED=true             # Allow 2FA setup (default: true)
# MIN_PASSWORD_LENGTH=8
# REQUIRE_UPPERCASE=true
# REQUIRE_NUMBERS=true
# SESSION_MAX_AGE=86400000            # Session lifetime in ms (default: 24h)
# CSRF_ENABLED=true                   # CSRF protection (default: true)
# SESSION_COOKIE_SECURE_LOCALHOST_OVERRIDE=false   # Keep false. Set true only for local http://localhost + NODE_ENV=production troubleshooting

# ==============================
# ALERTING / DELIVERY
# ==============================

# Comma-separated days-before-expiry thresholds (e.g. 30,14,7,1,0)
# ALERT_THRESHOLDS=30,14,7,1,0

# Maximum delivery attempts before giving up
# ALERT_MAX_ATTEMPTS=20

# Delay between retry attempts in ms (default: 5 min)
# ALERT_RETRY_DELAY_MS=300000

# Delivery window defaults (UTC times)
# DELIVERY_WINDOW_DEFAULT_START=07:00
# DELIVERY_WINDOW_DEFAULT_END=18:00
# DELIVERY_WINDOW_DEFAULT_TZ=UTC

# How long (ms) to defer a message that falls outside the delivery window
# DELIVERY_WINDOW_DEFERRAL_MS=

# Test override: force the alert scheduler to think today is a specific UTC day
# ALERT_TEST_UTC_DAY=

# ==============================
# PLAN / RESOURCE LIMITS (OSS defaults are unlimited)
# ==============================
# JSON maps of plan -> limit. In core, only the "oss" plan applies.
# Example: PLAN_TOKEN_LIMITS={"oss":999999}

# PLAN_TOKEN_LIMITS={"oss":999999}
# PLAN_ALERT_LIMITS={"oss":999999}
# INTEGRATION_SCAN_LIMITS={"oss":999999}
# CONTACT_GROUP_LIMITS={"oss":999999}
# CONTACT_GROUP_MEMBER_LIMITS={"oss":999999}
# WORKSPACE_PLAN_LIMITS={"oss":999999}
# MEMBER_PLAN_LIMITS={"oss":999999}

# ==============================
# WEBHOOKS
# ==============================

# Allowed webhook destination hosts (comma-separated)
# WEBHOOK_PROVIDER_HOSTS=hooks.slack.com,discord.com
# WEBHOOK_EXTRA_PROVIDER_HOSTS=custom.webhook.host

# Allow webhooks to any host (not recommended in production)
# WEBHOOK_ALLOW_ALL_HOSTS=false

# ==============================
# METRICS / OBSERVABILITY (optional)
# ==============================

# Enable Prometheus metrics endpoint on the API
# ENABLE_METRICS=false

# Prometheus Pushgateway URL for the worker
# PUSHGATEWAY_URL=http://pushgateway:9091

# Environment label for metrics
# ENVIRONMENT_SUFFIX=production

# ==============================
# RATE LIMITING
# ==============================

# Global API rate limiting
# RATE_LIMIT_WINDOW=60000       # Window in ms (default: 1 min)
# RATE_LIMIT_MAX=100            # Max requests per window

# API/auth limiter tuning (defaults shown for production mode)
# GLOBAL_RATE_LIMIT_WINDOW_MS=60000
# GLOBAL_RATE_LIMIT_MAX=300
# GLOBAL_SLOWDOWN_WINDOW_MS=900000
# GLOBAL_SLOWDOWN_DELAY_AFTER=50
# GLOBAL_SLOWDOWN_DELAY_MS=500
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_EMAIL_RATE_LIMIT_MAX=5
# PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
# PASSWORD_RESET_RATE_LIMIT_MAX=5
# PASSWORD_RESET_EMAIL_RATE_LIMIT_MAX=3
# EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000
# EMAIL_VERIFICATION_RATE_LIMIT_MAX=20
# AUTH_SLOWDOWN_WINDOW_MS=900000
# AUTH_SLOWDOWN_DELAY_AFTER=5
# AUTH_SLOWDOWN_DELAY_MS=500
# AUTH_SLOWDOWN_MAX_DELAY_MS=10000
# API_RATE_LIMIT_WINDOW_MS=900000
# TEST_API_RATE_LIMIT_WINDOW_MS=900000
# TEST_API_RATE_LIMIT_MAX=1000
# PLAN_API_LIMITS=oss:6000

# Test webhook endpoint limiter tuning
# TEST_WEBHOOK_RATE_LIMIT_1M_WINDOW_MS=60000
# TEST_WEBHOOK_RATE_LIMIT_1M_MAX=5
# TEST_WEBHOOK_RATE_LIMIT_5M_WINDOW_MS=300000
# TEST_WEBHOOK_RATE_LIMIT_5M_MAX=10
# TEST_WEBHOOK_COOLDOWN_MS=5000

# ==============================
# WORKER / API INTERNAL
# ==============================

# Shared key for worker-to-API authentication
# WORKER_API_KEY=                # Falls back to SESSION_SECRET if unset

# ==============================
# PORT SETTINGS
# ==============================

API_PORT=4000
DASHBOARD_PORT=5173

