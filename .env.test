# ============================================================
# TokenTimer Core - Test Environment Variables
# Used by: run-tests.sh / pnpm test
# These values must match docker-compose.test.yml services.
# ============================================================

NODE_ENV=test
TT_SKIP_COMPOSE_BUILD=0
TT_TEST_API_PORT=4000
TT_TEST_DB_PORT=5432
TT_TEST_MAILHOG_SMTP_PORT=1025
TT_TEST_MAILHOG_UI_PORT=8025

# --- API target (from the host / test runner perspective) ---
TEST_API_URL=http://localhost:4000

# --- Database (host-side access to Postgres container) ------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokentimer
DB_USER=tokentimer
DB_PASSWORD=password

# --- SMTP (MailHog running inside Docker) -------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.com
SMTP_PASS=test-password
FROM_EMAIL=noreply@tokentimer-test.local
FROM_EMAIL_NAME="TokenTimer Test"
TWILIO_AUTH_TOKEN=test-auth-token

# --- Session / Auth -----------------------------------------
SESSION_SECRET=test-session-secret-key

# --- Admin bootstrap (first run only) -----------------------
ADMIN_EMAIL=admin@localhost.local
ADMIN_PASSWORD=SecureTest123!@#
ADMIN_NAME="Test Admin"

# --- Alert delivery (wide window so tests always pass) ------
DELIVERY_WINDOW_DEFAULT_START=00:00
DELIVERY_WINDOW_DEFAULT_END=23:59
