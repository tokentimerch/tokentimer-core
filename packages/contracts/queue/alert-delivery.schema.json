{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert Delivery Message",
  "description": "Message to deliver an alert via configured channels",
  "type": "object",
  "properties": {
    "type": {
      "const": "alert-delivery"
    },
    "alert": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "workspaceId": { "type": "string", "format": "uuid" },
        "tokenId": { "type": "string", "format": "uuid" },
        "tokenName": { "type": "string" },
        "tokenType": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date" },
        "daysUntilExpiry": { "type": "integer" }
      },
      "required": ["id", "workspaceId", "tokenId"]
    },
    "channels": {
      "type": "array",
      "items": { "type": "string", "enum": ["email", "webhook", "whatsapp"] },
      "minItems": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["type", "alert", "channels", "timestamp"]
}
