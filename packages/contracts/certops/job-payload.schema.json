{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tokentimer.io/contracts/certops/job-payload.schema.json",
  "title": "CertOps M2 Job Payload",
  "description": "M2-A1 public, unsigned planning/reporting skeleton for future certificate lifecycle jobs under TOKENTIMER_CERTOPS_PLAN v1.7. This contract carries only public certificate references, target references, lifecycle action intent, and non-secret metadata. The action field is the M2 lifecycle action vocabulary, not the future M4 signed job dispatch protocol. Agent execution, job signing, attemptId, agentId/selector, nonce replay cache, signingKeyId, signature, signed dispatch, and related replay enforcement are M4 additions and are not required for M2 validation. Customer private key material and key-bearing bundles are outside this contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "jobId",
    "workspaceId",
    "certificateId",
    "action",
    "target",
    "keyMode",
    "requestedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "jobId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "Unique public job identifier. M4 signed dispatch adds replay-protection semantics."
    },
    "workspaceId": {
      "type": "string",
      "format": "uuid",
      "description": "Owning workspace identifier."
    },
    "certificateId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "Managed certificate identifier."
    },
    "tokenId": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Optional link to the existing tokens table."
    },
    "action": {
      "type": "string",
      "enum": ["renew", "deploy", "reload", "revoke", "noop"],
      "description": "Public certificate lifecycle action requested by the control plane."
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedBy": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["actorType"],
      "properties": {
        "actorType": {
          "type": "string",
          "enum": ["user", "system", "automation"]
        },
        "actorId": {
          "type": ["string", "null"],
          "maxLength": 128
        },
        "displayName": {
          "type": ["string", "null"],
          "maxLength": 256
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["domain", "endpoint", "kubernetes", "appliance", "load-balancer", "external"]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Non-secret deployment or observation reference."
        },
        "managedCertificateId": {
          "type": ["string", "null"],
          "maxLength": 128
        },
        "certificateInstanceId": {
          "type": ["string", "null"],
          "maxLength": 128
        },
        "fingerprintSha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "keyMode": {
      "type": "string",
      "enum": [
        "agent-local",
        "proxy-agent-local",
        "cert-manager-managed",
        "appliance-managed",
        "hsm-managed",
        "vault-managed",
        "os-store-managed",
        "external-unknown"
      ],
      "description": "Non-secret mode describing where key custody remains outside the control plane."
    },
    "keyReference": {
      "type": ["string", "null"],
      "maxLength": 512,
      "description": "Opaque non-secret reference to external execution-plane key custody."
    },
    "metadata": {
      "type": "array",
      "maxItems": 32,
      "description": "Public, sanitized metadata entries only.",
      "items": {
        "$ref": "#/definitions/publicMetadataEntry"
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time",
      "description": "M4-reserved signed job dispatch timestamp. Optional in M2-A1 and not required for M2 validation."
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "M4-reserved signed job validity bound. Optional in M2-A1 and not required for M2 validation."
    },
    "nonce": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "M4-reserved single-use nonce for signed job replay protection. Optional in M2-A1 and not required for M2 validation."
    },
    "signingKeyId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "M4-reserved identifier of the control-plane operational signing key. Optional in M2-A1 and not required for M2 validation."
    },
    "signature": {
      "type": "string",
      "minLength": 64,
      "maxLength": 1024,
      "description": "M4-reserved signature over the canonical job payload. Optional in M2-A1 and not required for M2 validation."
    }
  },
  "definitions": {
    "publicMetadataEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(?!.*(?:[Pp][Rr][Ii][Vv][Aa][Tt][Ee][-_]?[Kk][Ee][Yy]|[Ee][Nn][Cc][Rr][Yy][Pp][Tt][Ee][Dd][-_]?[Pp][Rr][Ii][Vv][Aa][Tt][Ee][-_]?[Kk][Ee][Yy]|[Kk][Ee][Yy][-_]?[Mm][Aa][Tt][Ee][Rr][Ii][Aa][Ll]|[Pp][Ff][Xx][-_]?[Bb][Ll][Oo][Bb]|[Jj][Kk][Ss][-_]?[Bb][Ll][Oo][Bb]|[Tt][Ll][Ss][-_]?[Kk][Ee][Yy]|[Cc][Aa][-_]?[Pp][Rr][Ii][Vv][Aa][Tt][Ee][-_]?[Kk][Ee][Yy]|[Kk][Ee][Yy][Ss][Tt][Oo][Rr][Ee][-_]?[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee][-_]?[Kk][Ee][Yy][-_]?[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Kk][Ee][Yy][-_]?[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Kk][Ee][Yy][-_]?[Pp][Ee][Mm]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]))[A-Za-z0-9_.:-]{1,64}$"
        },
        "value": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 512
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
